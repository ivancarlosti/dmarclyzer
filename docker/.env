# DMARClyzer Environment Configuration

# IMAP Connection Setup
IMAP_SERVER=imap.example.com
IMAP_PORT=993
IMAP_USER=dmarc@example.com
IMAP_PASSWORD=your_imap_password
IMAP_FOLDER=INBOX
# Define folders to move messages to after processing. Leave blank to just mark as Read.
IMAP_MOVE_FOLDER=processed
IMAP_MOVE_FOLDER_ERR=error
# How often to check for new emails (in seconds)
FETCH_INTERVAL=300

# MariaDB Connection Details
DB_HOST=db
DB_NAME=dmarc
DB_USER=dmarcuser
DB_PASSWORD=dmarcpass
DB_ROOT_PASSWORD=root_password

# Web Server & Reverse Proxy
# Port exposed to the Docker host machine
PORT=8080
# If you are using a reverse proxy (like Nginx), you can define the domain name here
DOMAIN=dmarc.example.com
